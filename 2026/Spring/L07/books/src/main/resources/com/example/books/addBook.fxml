<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.books.AddBookController">
   <children>
      <TextField fx:id="idTextFiend" layoutX="100.0" layoutY="43.0" />
      <TextField fx:id="nameTextField" layoutX="119.0" layoutY="97.0" />
      <Label layoutX="61.0" layoutY="47.0" text="ID:" />
      <Label layoutX="59.0" layoutY="101.0" text="Name:" />
      <TableView fx:id="bookTable" layoutX="59.0" layoutY="154.0" prefHeight="200.0" prefWidth="336.0">
        <columns>
          <TableColumn fx:id="idCol" prefWidth="113.0" text="ID" />
          <TableColumn fx:id="nameCol" prefWidth="222.0" text="Name" />
        </columns>
      </TableView>
      <Button layoutX="300.0" layoutY="106.0" mnemonicParsing="false" onAction="#addBookOnClick" text="Add book" />
      <Label fx:id="outputLable" layoutX="395.0" layoutY="26.0" prefHeight="112.0" prefWidth="193.0" wrapText="true" />
      <Button layoutX="427.0" layoutY="354.0" mnemonicParsing="false" onAction="#laodDataFromBinFIle" text="Load data from bin file" />
   </children>
</AnchorPane>
